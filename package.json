{
  "name": "chuckts",
  "version": "0.1.0",
  "description": "Embedded HTTP traffic inspector for React Native — like a mini Charles Proxy inside your app",
  "main": "lib/index.js",
  "module": "lib/index.esm.js",
  "types": "lib/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "bob build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "echo 'Run npm run build to compile'"
  },
  "keywords": [
    "react-native",
    "http",
    "inspector",
    "debugger",
    "network",
    "chucker",
    "devtools"
  ],
  "author": "LeoMello07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeoMello07/ChuckTS.git"
  },
  "bugs": {
    "url": "https://github.com/LeoMello07/ChuckTS/issues"
  },
  "homepage": "https://github.com/LeoMello07/ChuckTS#readme",
  "peerDependencies": {
    "axios": ">=0.21.0",
    "react": ">=17.0.0",
    "react-native": ">=0.64.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "zustand": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.5",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "axios": "^1.6.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "react": "^18.3.0",
    "react-native": "^0.73.0",
    "react-native-builder-bob": "^0.23.2",
    "typescript": "^5.4.0",
    "zustand": "^4.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(zustand)/)"
    ],
    "testMatch": [
      "**/__tests__/**/*.(test|spec).(ts|tsx|js)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "globals": {
      "__DEV__": true
    },
    "setupFiles": [
      "./__tests__/setup.ts"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^@react-native-clipboard/clipboard$": "<rootDir>/__mocks__/@react-native-clipboard/clipboard.js"
    },
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
